# Firebase web configuration. These identify the Firebase web app; access to
# school data is controlled by firestore.rules, not by hiding these values.
# Set to true to use local demo data without removing Firebase configuration.
VITE_DEMO_MODE=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-only Gemini configuration.
# Never use the VITE_ prefix for a secret: VITE_ values are sent to browsers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Production server configuration for VPS/Coolify.
PORT=3000

# Demo Guru Credentials (hanya digunakan saat VITE_DEMO_MODE=true)
VITE_DEMO_GURU_EMAIL=
VITE_DEMO_GURU_USERNAME=
VITE_DEMO_GURU_PASSWORD=
